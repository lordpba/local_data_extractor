# Ollama Configuration

# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model to use (must support vision/multimodal)
# Recommended:
#   llama3.2-vision:11b  — Best overall right now, 11B/12GB
#   glm-ocr:latest       — #1 OCR benchmark, 0.9B/2.2GB, works on any GPU (requires Ollama >= 0.17.7)
#   deepseek-ocr:latest  — Very good OCR, 7B/10GB loaded, requires Ollama >= 0.13.0
#   llava:7b             — General vision, 7B
OLLAMA_MODEL=llama3.2-vision:11b

# Ollama Request Timeout in seconds (default: 3600)
# Increase this if you are using small/slow hardware (e.g., no GPU) 
# and the requests time out during extraction.
OLLAMA_TIMEOUT=3600

# Maximum image width for PDF/image conversion (smaller = faster, less VRAM)
# Default: 1024. Good values: 768 (fast), 1024 (balanced), 1600 (high quality)
IMAGE_MAX_WIDTH=1024

# Skip image enhancement (contrast/sharpness/brightness adjustments)
# Set to true to speed up processing for clean/printed documents
SKIP_IMAGE_ENHANCE=false

# Delay in seconds between batch file processing (default: 5)
# Increase if you get empty responses during batch processing
BATCH_DELAY=5

# Flask server port
PORT=5000
